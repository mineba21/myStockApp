# ── Telegram ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Core Scan ───────────────────────────────────────────────────
SCAN_LOOKBACK_DAYS=7
MA_PERIOD=150
MA_SLOPE_PERIOD=10
VOLUME_AVG_PERIOD=20

# ── BREAKOUT (돌파) ─────────────────────────────────────────────
BREAKOUT_BASE_LOOKBACK_DAYS=60
BREAKOUT_MIN_BASE_DAYS=15
BREAKOUT_VOLUME_RATIO=1.5
BREAKOUT_MAX_EXTENDED_PCT=15.0
REQUIRE_PRICE_ABOVE_MA50=true

# ── RE_BREAKOUT (재돌파) ────────────────────────────────────────
REBREAKOUT_BASE_LOOKBACK_DAYS=30
REBREAKOUT_MAX_PULLBACK_PCT=15.0
REBREAKOUT_VOLUME_RATIO=1.5
REBREAKOUT_REQUIRE_VOLUME_DRYUP=false

# ── REBOUND (눌림목 반등) ───────────────────────────────────────
REBOUND_MA_PERIOD=50
REBOUND_TOUCH_PCT=3.0
REBOUND_CONFIRM_PCT=2.0
REBOUND_MAX_PULLBACK_PCT=12.0
REBOUND_REQUIRE_VOLUME_DRYUP=false
REBOUND_ALLOW_PIVOT_RETEST=true

# ── Market Filter ────────────────────────────────────────────────
ENABLE_MARKET_FILTER=true
BLOCK_NEW_BUYS_IN_BEAR=true
CAUTION_MODE=allow_with_flag

# ── Weinstein v2 Weekly (원전 충실) ────────────────────────────
# WEINSTEIN_MODE: legacy | v2 | strict
WEINSTEIN_MODE=legacy
ENABLE_WEINSTEIN_V2=false
WEINSTEIN_V2_STRICT=false
# 주봉 30-SMA 기반 Stage 판정 (Weinstein 원전 기준)
WEEKLY_MA_LONG=30
WEEKLY_MA_SHORT=10
DAILY_MA_FAST=50
DAILY_MA_SLOW=150
BREAKOUT_WEEKLY_VOL_RATIO=2.0
BREAKOUT_DAILY_VOL_RATIO=3.0
# Mansfield RS (0선 기준 절대 강도)
RS_LOOKBACK_WEEKS=52
BASE_MIN_WEEKS=5
PIVOT_LOOKBACK_WEEKS=26
BASE_MAX_WIDTH_PCT=15.0
BASE_TIGHT_WIDTH_PCT=8.0
MANSFIELD_MIN_RS=0.0

# ── Universe ────────────────────────────────────────────────────
US_UNIVERSE=sp500+nasdaq100

# ── Schedule ────────────────────────────────────────────────────
SCHEDULE_TIMES=09:00,14:00,22:00

# ── KIS ─────────────────────────────────────────────────────────
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PROD_CD=01
KIS_IS_PAPER=true
